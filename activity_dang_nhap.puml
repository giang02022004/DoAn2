@startuml "Activity Diagram: Dang nhap"
|Người dùng|
start
:Truy cập trang Đăng nhập;
:Nhập Email & Mật khẩu;
:Nhấn Đăng nhập;

|Hệ thống (Spring Security)|
:Tìm kiếm tài khoản theo Email;
if (Tài khoản tồn tại?) then (Không)
    :Thông báo email sai;
    stop
else (Có)
    :Kiểm tra trạng thái enabled/lock;
    if (Đang bị khóa?) then (Có)
        :Thông báo tài khoản bị khóa;
        stop
    else (Không)
        :So khớp mật khẩu (BCrypt);
        if (Mật khẩu đúng?) then (Không)
            :Thông báo sai mật khẩu;
            stop
        else (Đúng)
            :Thiết lập Authentication Session;
            :Ghi nhận quyền (Roles);
            if (Vai trò?) then (Quản trị/Nhân viên)
                :Chuyển hướng đến Dashboard;
            else (Khách hàng)
                :Chuyển hướng đến Trang chủ;
            endif
        endif
    endif
endif

|Người dùng|
:Nhận giao diện đã đăng nhập;
stop
@enduml
