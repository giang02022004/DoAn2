@startuml "Chi tiet Use Case: Dang ky - 10/10 Accuracy"
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false
skinparam actorStyle stickman

' --- Actors ---
actor "Khách vãng lai" as Guest

rectangle "Hệ thống Bán hàng DoAn2" {
    usecase "Đăng ký tài khoản" as Main
    usecase "Kiểm tra hợp lệ thông tin" as UC_Check
    usecase "Xác thực qua Email" as UC_Verify
    
    ' --- Logic ---
    ' 1. Include: Đăng ký bắt buộc phải kiểm tra thông tin (Base -> Sub)
    Main .down.> UC_Check : <<include>>
    
    ' 2. Extend: Xác thực Email trỏ về phía Đăng ký (Extension -> Base)
    UC_Verify .left.> Main : <<extend>>
}

' Connections
Guest --> Main

@enduml
