@startuml "Chi tiet Use Case: Dat hang - 10/10 Accuracy"
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false
skinparam actorStyle stickman

' --- Actors ---
actor "Khách hàng" as Customer

rectangle "Hệ thống Bán hàng DoAn2" {
    usecase "Đặt hàng" as Main
    
    usecase "Chọn địa chỉ nhận hàng" as UC_Addr
    usecase "Chọn phương thức thanh toán" as UC_PayType
    usecase "Tính tổng giá trị đơn hàng" as UC_Calc
    
    usecase "Thanh toán (Online/COD)" as UC_Payment
    usecase "Áp dụng mã giảm giá" as UC_Promo
    
    ' --- Logic ---
    ' 1. Include: Các bước bắt buộc trong quy trình đặt hàng (Base -> Sub)
    Main .down.> UC_Addr : <<include>>
    Main .down.> UC_PayType : <<include>>
    Main .down.> UC_Calc : <<include>>
    
    ' 2. Extend: Các chức năng mở rộng hoặc tùy chọn (Extension -> Base)
    UC_Payment .left.> Main : <<extend>>
    UC_Promo .up.> Main : <<extend>>
}

' Connections
Customer --> Main

@enduml
