@startuml "He thong Quan ly Ban hang DoAn2 - Tong quat"
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false
skinparam actorStyle stickman

' --- Actors ---
actor "Khách vãng lai" as Guest
actor "Khách hàng" as Customer
actor "Nhân viên" as Employee
actor "Quản trị viên" as Admin

' Hierarchy
Admin -|> Employee
Customer -|> Guest

rectangle "Hệ thống Bán hàng DoAn2" {
  
  ' Authentication & Security
  usecase "Đăng nhập" as UC_Login
  usecase "Đăng xuất" as UC_Logout
  usecase "Đổi mật khẩu" as UC_ChangePass
  usecase "Quên mật khẩu" as UC_Forgot
  
  ' Shopping Core
  usecase "Xem sản phẩm" as UC_ViewProd
  usecase "Tìm kiếm sản phẩm" as UC_Search
  usecase "Xem tin tức" as UC_News
  usecase "Gửi liên hệ" as UC_Contact
  usecase "Đăng ký" as UC_Register
  
  usecase "Quản lý giỏ hàng" as UC_Cart
  usecase "Đặt hàng" as UC_Order
  usecase "Thanh toán (Online/COD)" as UC_Pay
  usecase "Xem lịch sử mua hàng" as UC_History
  usecase "Hủy đơn hàng" as UC_Cancel
  usecase "Đánh giá sản phẩm" as UC_Review
  
  ' Management & Ops
  usecase "Quản lý sản phẩm" as UC_ManageProd
  usecase "Quản lý loại & hãng" as UC_ManageCat
  usecase "Quản lý đơn hàng" as UC_ManageOrder
  usecase "Quản lý khuyến mãi" as UC_ManagePromo
  usecase "Quản lý bài viết" as UC_ManageBlog
  usecase "Quản lý nhân sự" as UC_ManageStaff
  usecase "Phân quyền & Bảo mật" as UC_Security
  usecase "Thống kê & Báo cáo" as UC_Report

  ' Detailed Relationships
  UC_Login <.down. UC_Forgot : <<extend>>
  UC_Order .down.> UC_Pay : <<include>>
  UC_History <.down. UC_Cancel : <<extend>>
  
  UC_ViewProd <.down. UC_Search : <<extend>>
}

' --- Connections ---

' Guest Actions
Guest --> UC_ViewProd
Guest --> UC_News
Guest --> UC_Register
Guest --> UC_Contact

' Customer Flow
Customer --> UC_Login
Customer --> UC_Logout
Customer --> UC_ChangePass
Customer --> UC_Cart
Customer --> UC_Order
Customer --> UC_History
Customer --> UC_Review

' Employee Flow
Employee --> UC_Login
Employee --> UC_Logout
Employee --> UC_ChangePass
Employee --> UC_ManageProd
Employee --> UC_ManageCat
Employee --> UC_ManageOrder
Employee --> UC_ManageBlog
Employee --> UC_ManagePromo

' Admin Flow
Admin --> UC_ManageStaff
Admin --> UC_Security
Admin --> UC_Report

@enduml
