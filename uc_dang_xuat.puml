@startuml "Chi tiet Use Case: Dang xuat - 10/10 Accuracy"
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false
skinparam actorStyle stickman

' --- Actors ---
actor "Khách hàng" as Customer
actor "Nhân viên" as Employee
actor "Quản trị viên" as Admin

' Hierarchy
Admin -|> Employee

rectangle "Hệ thống Bán hàng DoAn2" {
    usecase "Đăng xuất" as Main
    usecase "Xác nhận đăng xuất" as UC_Confirm
    
    ' --- Logic ---
    ' 1. Extend: Xác nhận là bước mở rộng/tùy chọn trước khi thoát (Extension -> Base)
    UC_Confirm .up.> Main : <<extend>>
}

' Connections
Customer --> Main
Employee --> Main
' Admin kế thừa Employee nên cũng có quyền logout

@enduml
